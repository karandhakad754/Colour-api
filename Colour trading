package main

import (
	"context"
	"encoding/json"
	"log"
	"math/rand"
	"net/http"
	"os"
	"time"

	firebase "firebase.google.com/go"
	"google.golang.org/api/option"
)

type Result struct {
	Period string `json:"period"`
	Number int    `json:"number"`
	Color  string `json:"color"`
}

var current Result

func generateResult() Result {
	rand.Seed(time.Now().UnixNano())
	num := rand.Intn(10)

	color := "green"
	if num%2 == 0 {
		color = "red"
	}
	if num == 0 || num == 5 {
		color = "violet"
	}

	return Result{
		Period: time.Now().Format("200601021504"),
		Number: num,
		Color:  color,
	}
}

func pushToFirebase(res Result) {
	ctx := context.Background()

	opt := option.WithCredentialsFile("serviceAccountKey.json")
	app, err := firebase.NewApp(ctx, nil, opt)
	if err != nil {
		log.Println(err)
		return
	}

	client, err := app.Database(ctx)
	if err != nil {
		log.Println(err)
		return
	}

	ref := client.NewRef("current")
	ref.Set(ctx, res)
}

func scheduler() {
	for {
		res := generateResult()
		current = res
		pushToFirebase(res)
		time.Sleep(60 * time.Second)
	}
}

func handler(w http.ResponseWriter, r *http.Request) {
	json.NewEncoder(w).Encode(current)
}

func main() {
	go scheduler()

	http.HandleFunc("/result", handler)

	port := os.Getenv("PORT")
	if port == "" {
		port = "8080"
	}

	http.ListenAndServe(":"+port, nil)
}
